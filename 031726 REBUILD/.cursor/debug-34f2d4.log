-ob-text-sec: rgba(37,37,37,0.72);\n  --ob-text-dim: rgba(37,37,37,0.50);\n  --glass-bg: rgba(37,37,37,0.06);\n  --glass-border: rgba(37,37,37,0.12);\n}\n\n/* Ensure onboarding icons follow currentColor */\n.ob-screen .ob-pad button svg { stroke: currentColor !important; fill: none !important; }\n/* Ensure text defaults are not forced globally; allow component CSS to control alignment */\nbody { font-family: 'Barlow', sans-serif !important; }\n\n/* Fix the 'wonky' centering */\n.ob-screen {\n    display: flex !important;\n    flex-direction: column;\n    justify-content: flex-start !important;\n    align-items: flex-start !important;\n    min-height: 100dvh;\n    text-align: left !important;\n    padding: 60px 24px !important;\n}\n\n/* Button/icon reset ONLY for the main app shell so onboarding keeps themed controls */\n.app button, .app button * { color: #000000 !important; }\n.app button svg { fill: #000000 !important; stroke: #000000 !important; }\n\n/* Ensure onboarding mood buttons/icons inherit their intended colors */\n.ob-screen .ob-pad button { color: var(--ob-text-head) !important; }\n.ob-screen .ob-pad button svg { stroke: currentColor !important; fill: none !important; }\n  .ob-wrap {\n    min-height:100%; width:100%; display:flex; flex-direction:column; position:relative; overflow:visible;\n    background:var(--ob-page-bg); font-family:'Barlow',sans-serif; font-weight:300;\n    box-sizing:border-box;\n  }\n  /* Ensure mood variables are available on the root/body so JS can update them */\n  :root, body, .ob-screen { --mood-color: var(--ob-accent, #FFBF65); }\n  /* orbs — static layer + sheen when in color mode */\n  .ob-orbs-layer { position:fixed; inset:0; z-index:0; pointer-events:none; }\n  .ob-orbs-layer::after { content:''; position:absolute; inset:0; pointer-events:none; background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 40%, rgba(255,255,255,0.02) 60%, transparent 100%); }\n  .ob-label { display:none; }\n  .ob-shell { widt