ading { font-size:42px; font-weight:600; letter-spacing:-0.03em; line-height:1.05; color:var(--ob-text-head); margin-bottom:18px; }\n  .ob-heading em { font-style:italic; font-weight:300; color:var(--ob-accent); }\n  .ob-body { font-size:15px; line-height:1.52; color:var(--ob-text-body); font-weight:400; }\n  :root { --ob-box-bg: rgba(255,255,255,0.08); --ob-box-border: rgba(255,255,255,0.13); }\n  .ob-sci-blocks { display:flex; flex-direction:column; gap:10px; margin-top:20px; }\n  .ob-sci {\n    padding:14px 16px; border-radius:14px;\n    background:var(--ob-box-bg); border:1px solid var(--ob-box-border);\n    backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);\n"}],"sheets":[{"href":"https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Share+Tech+Mono&display=swap","ownerNodeId":null,"rulesSample":"CORS_OR_ERROR"},{"href":null,"ownerNodeId":"STYLE","rulesSample":"*, ::before, ::after { box-sizing: border-box; margin: 0px; padding: 0px; }|||html, body, #root { height: 100dvh; margin: 0px; }|||html { width: 100%; max-width: 100vw; overflow: hidden auto; background: rgb(10, 10, 15); text-size-adjust: 100%; touch-action: auto; }|||body { width: 100%; max-width: 100vw; padding: 0px; overflow: hidden auto; background: rgb(10, 10, 15); touch-action: auto; }|||#root { width: 100%; max-width: 100vw; overflow: hidden auto; }|||#load-err { display: none; position: fixed; inset: 0px; background: rgb(10, 10, 15); color: rgb(255, 107, 107); font-family: sans-serif; font-size: 14px; padding: 40px; white-space: pre-wrap; }|||* { color: rgb(255, 255, 255); font-family: Barlow, sans-serif !important; text-align: left !important; }|||:root { --axis-white: #f6f7f8; --axis-black: #252525; }|||.ob-screen[data-theme=\"dark\"], .ob-screen[data-night=\"false\"], .ob-screen { --ob-text-head: var(--axis-white); --ob-text-body: rgba(246,247,248,0.90); --ob-text-sec: rgba(246,247,248,0.72); --ob-text-dim: rgba(246,247,248,0.50