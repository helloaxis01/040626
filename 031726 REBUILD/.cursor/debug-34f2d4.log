{"sessionId":"34f2d4","runId":"initial","hypothesisId":"H-main","location":"index-onboarding-rebuild.html:instrument","message":"stylesheet_and_element_snapshot","data":{"url":"http://127.0.0.1:8000/index-onboarding-rebuild.html","markersFound":[{"marker":"display:inline-flex; align-items:center; justify-content:center","foundInDoc":true},{"marker":"background: rgba(255,255,255,0.08)","foundInDoc":true},{"marker":"--axis-white: #f6f7f8","foundInDoc":true}],"stylesCount":2,"stylesSample":[{"owner":"style#0","text":"\n \n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n  html, body, #root { height: 100dvh; margin: 0; }\n  html { width: 100%; max-width: 100vw; overflow-x: hidden; overflow-y: auto; background: #0a0a0f; -webkit-text-size-adjust: 100%; touch-action: auto; }\n  body { width: 100%; max-width: 100vw; padding: 0; overflow-x: hidden; overflow-y: auto; background: #0a0a0f; touch-action: auto; }\n  #root { width: 100%; max-width: 100vw; overflow-x: hidden; overflow-y: auto; }\n  #load-err { display:none; position:fixed; inset:0; background:#0a0a0f; color:#ff6b6b;\n    font-family:sans-serif; font-size:14px; padding:40px; white-space:pre-wrap; }\n/* Force Barlow on everything immediately */\n* {\n    font-family: 'Barlow', sans-serif !important;\n    text-align: left !important;\n    color: #ffffff;\n}\n/* AXIS canonical colors */\n:root {\n  --axis-white: #f6f7f8;\n  --axis-black: #252525;\n}\n\n/* Onboarding: map existing ob- variables to AXIS colors (dark/light contexts) */\n.ob-screen[data-theme=\"dark\"], .ob-screen[data-night=\"false\"], .ob-screen {\n  --ob-text-head: var(--axis-white);\n  --ob-text-body: rgba(246,247,248,0.90);\n  --ob-text-sec: rgba(246,247,248,0.72);\n  --ob-text-dim: rgba(246,247,248,0.50);\n  --glass-bg: rgba(246,247,248,0.06);\n  --glass-border: rgba(246,247,248,0.12);\n}\n.ob-screen[data-theme=\"light\"], .ob-screen.light {\n  --ob-text-head: var(--axis-black);\n  --ob-text-body: rgba(37,37,37,0.90);\n  --ob-text-sec: rgba(37,37,37,0.72);\n  --ob-text-dim: rgba(37,37,37,0.50);\n  --glass-bg: rgba(37,37,37,0.06);\n  --glass-border: rgba(37,37,37,0.12);\n}\n\n/* Mood icon box uses inline --accent; SVG stroke reads it—do not override */\n/* Ensure text defaults are not forced globally; allow component CSS to control alignment */\nbody { font-family: 'Barlow', sans-serif !important; }\n\n/* Fix the 'wonky' centering */\n.ob-screen {\n    display: flex !important;\n    flex-direction: column;\n    justify-content: flex-start !important;\n    align-items: flex-start !important;\n    min-height: 100dvh;\n    text-align: left !important;\n    padding: 60px 24px !important;\n}\n\n/* Button/icon reset ONLY for the main app shell so onboarding keeps themed controls */\n.app button, .app button * { color: #000000 !important; }\n.app button svg { fill: #000000 !important; stroke: #000000 !important; }\n\n/* Mood button labels use inline colors; do not force button color (breaks icon accent) */\n  .ob-wrap {\n    min-height:100%; width:100%; display:flex; flex-direction:column; position:relative; overflow:visible;\n    background:var(--ob-page-bg); font-family:'Barlow',sans-serif; font-weight:300;\n    box-sizing:border-box;\n  }\n  /* Ensure mood variables are available on the root/body so JS can update them */\n  :root, body, .ob-screen { --mood-color: var(--ob-accent, #FFBF65); }\n  /* orbs — static layer + sheen when in color mode */\n  .ob-orbs-layer { position:fixed; inset:0; z-index:0; pointer-events:none; }\n  .ob-orbs-layer::after { content:''; position:absolute; inset:0; pointer-events:none; background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 40%, rgba(255,255,255,0.02) 60%, transparent 100%); }\n  .ob-label { display:none; }\n  .ob-shell { width:100%; overflow-y:auto; overflow-x:hidden; -webkit-overflow-scrolling:touch; position:relative; z-index:1; flex:1; display:flex; flex-direction:column; box-sizing:border-box; }\n  .ob-screen { width:100%; min-height:100vh; display:flex; flex-direction:column; justify-content:flex-start; align-items:flex-start; position:relative; box-sizing:border-box; animation:obFadeIn 0.3s ease; text-align:left; }\n  @keyframes obFadeIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }\n  @keyframes obColorFadeIn { from { opacity:0; } to { opacity:1; } }\n  .ob-color-reveal { animation: obColorFadeIn 2.5s ease-out forwards; }\n  .ob-pad { padding:calc(env(safe-area-inset-top, 0px) + 72px) 32px calc(env(safe-area-inset-bottom, 0px) + 70px); flex:1; box-sizing:border-"},{"owner":"obcss-restore","text":"\n  @import url('https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');\n  html,body,#root{width:100%;margin:0;padding:0;}\n  .ob-wrap {\n    min-height:100%; width:100%; display:flex; flex-direction:column; position:relative; overflow:clip;\n    background:var(--ob-page-bg); font-family:'Barlow',sans-serif; font-weight:300;\n    box-sizing:border-box;\n  }\n  /* orbs — static layer + sheen when in color mode */\n  .ob-orbs-layer { position:fixed; inset:0; z-index:0; pointer-events:none; }\n  .ob-orbs-layer::after { content:''; position:absolute; inset:0; pointer-events:none; background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 40%, rgba(255,255,255,0.02) 60%, transparent 100%); }\n  .ob-label { display:none; }\n  .ob-shell { width:100%; overflow-y:auto; overflow-x:hidden; -webkit-overflow-scrolling:touch; position:relative; z-index:1; flex:1; display:flex; flex-direction:column; box-sizing:border-box; }\n  .ob-screen { width:100%; min-height:100vh; display:flex; flex-direction:column; position:relative; box-sizing:border-box; animation:obFadeIn 0.3s ease; }\n  @keyframes obFadeIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }\n  @