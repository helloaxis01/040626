ading { font-size:42px; font-weight:600; letter-spacing:-0.03em; line-height:1.05; color:var(--ob-text-head); margin-bottom:18px; }\n  .ob-heading em { font-style:italic; font-weight:300; color:var(--ob-accent); }\n  .ob-body { font-size:15px; line-height:1.52; color:var(--ob-text-body); font-weight:400; }\n  :root { --ob-box-bg: rgba(255,255,255,0.08); --ob-box-border: rgba(255,255,255,0.13); }\n  .ob-sci-blocks { display:flex; flex-direction:column; gap:10px; margin-top:20px; }\n  .ob-sci {\n    padding:14px 16px; border-radius:14px;\n    background:var(--ob-box-bg); border:1px solid var(--ob-box-border);\n    backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);\n"}],"sheets":[{"href":"https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Share+Tech+Mono&display=swap","ownerNodeId":null,"rulesSample":"CORS_OR_ERROR"},{"href":"http://127.0.0.1:8000/onboarding.css","ownerNodeId":"LINK","rulesSample":".ob-ext-nav, .ob-label { display: none; }|||.ob-wrap { position: fixed; inset: 0px; overflow: hidden; color: var(--ob-text-body); font-family: Barlow, sans-serif; background: transparent; }|||.ob-shell { height: 100%; overflow-y: auto; scroll-snap-type: y mandatory; position: relative; z-index: 100; }|||.ob-orb-bg { position: fixed; inset: 0px; z-index: 0; pointer-events: none; }|||.ob-orb-bg::after { content: \"\"; position: absolute; inset: 0px; background: linear-gradient(to right top, rgba(255, 255, 255, 0.03) 0%, transparent 85%); pointer-events: none; z-index: 1; }|||.ob-screen { height: 100%; scroll-snap-align: start; display: block; overflow-y: auto; padding: 110px 24px 150px; box-sizing: border-box; }|||.ob-pad { max-width: 480px; margin: 0px auto; width: 100%; }|||.ob-eyebrow { font-size: 13px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ob-accent); margin-bottom: 12px; }|||.ob-heading { font-size: 40px; font-weight: 600; letter-spacing: -0.03em; line-height: 