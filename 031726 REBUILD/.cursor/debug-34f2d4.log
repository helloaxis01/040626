{"sessionId":"34f2d4","runId":"initial","hypothesisId":"H-main","location":"index-onboarding-rebuild.html:instrument","message":"stylesheet_and_element_snapshot","data":{"url":"http://127.0.0.1:8000/index-onboarding-rebuild.html","markersFound":[{"marker":"display:inline-flex; align-items:center; justify-content:center","foundInDoc":true},{"marker":"background: rgba(255,255,255,0.08)","foundInDoc":true},{"marker":"--axis-white: #f6f7f8","foundInDoc":true}],"stylesCount":2,"stylesSample":[{"owner":"style#0","text":"\n \n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n  html, body, #root { height: 100dvh; margin: 0; }\n  html { width: 100%; max-width: 100vw; overflow-x: hidden; overflow-y: auto; background: #0a0a0f; -webkit-text-size-adjust: 100%; touch-action: auto; }\n  body { width: 100%; max-width: 100vw; padding: 0; overflow-x: hidden; overflow-y: auto; background: #0a0a0f; touch-action: auto; }\n  #root { width: 100%; max-width: 100vw; overflow-x: hidden; overflow-y: auto; }\n  #load-err { display:none; position:fixed; inset:0; background:#0a0a0f; color:#ff6b6b;\n    font-family:sans-serif; font-size:14px; padding:40px; white-space:pre-wrap; }\n/* Force Barlow on everything immediately */\n* {\n    font-family: 'Barlow', sans-serif !important;\n    text-align: left !important;\n    color: #ffffff;\n}\n/* AXIS canonical colors */\n:root {\n  --axis-white: #f6f7f8;\n  --axis-black: #252525;\n}\n\n/* Onboarding: map existing ob- variables to AXIS colors (dark/light contexts) */\n.ob-screen[data-theme=\"dark\"], .ob-screen[data-night=\"false\"], .ob-screen {\n  --ob-text-head: var(--axis-white);\n  --ob-text-body: rgba(246,247,248,0.90);\n  --ob-text-sec: rgba(246,247,248,0.72);\n  --ob-text-dim: rgba(246,247,248,0.50);\n  --glass-bg: rgba(246,247,248,0.06);\n  --glass-border: rgba(246,247,248,0.12);\n}\n.ob-screen[data-theme=\"light\"], .ob-screen.light {\n  --ob-text-head: var(--axis-black);\n  --ob-text-body: rgba(37,37,37,0.90);\n  -